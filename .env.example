# Plina Landing — variáveis de ambiente.
# Copie para .env.local e preencha. .env.local NUNCA vai para o git.

# ─── SMTP (lead capture institucional via app/actions/submit-lead.ts) ───
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=contato@plina.finance
SMTP_PASS=
LEAD_EMAIL_TO=
# F-M1-7: base URL absoluta pros links nos emails transacionais ao cedente.
APP_BASE_URL=https://plina.finance

# ─── Vercel Blob (F-M1-8 · comprovante PDF privado) ───
# Sem este token, a geração/upload do comprovante vira no-op (dev/test).
BLOB_READ_WRITE_TOKEN=

# ─── Stellar (POC + MVP) ───
# Smoke test só roda em TESTNET. Mainnet exige multisig + smart account Soroban.
STELLAR_NETWORK=TESTNET
# Opcional — defaults: testnet=https://horizon-testnet.stellar.org · public=https://horizon.stellar.org
STELLAR_HORIZON_URL=
# Asset code on-chain. Stellar não permite hífen; "PLINA-RF" é apenas branding.
ASSET_CODE=PLINARF
# F-M3-3: code da classe Subordinada (PLINARFB). PLINARF legacy = Sênior;
# Subordinada ganha o code separado pra zero churn em holders existentes.
ASSET_CODE_SUBORDINADA=PLINARFB
# Secrets do issuer/distributor — preencher após smoke test verde, com chaves persistentes.
# JAMAIS usar chaves de mainnet aqui no POC. JAMAIS commitar este arquivo preenchido.
STELLAR_ISSUER_SECRET=
STELLAR_DISTRIBUTOR_SECRET=
# F-M0-4: pisos de saldo (XLM) pra alarme (não bloqueia, só loga). Defaults no código.
ISSUER_BALANCE_FLOOR=5
DISTRIBUTOR_BALANCE_FLOOR=5
# F-M0-1: custódia Fireblocks (mainnet). Em testnet pode deixar vazio (usa secret em env).
# Em STELLAR_NETWORK=PUBLIC, issuer/distributor EXIGEM Fireblocks — sem isso, assinatura falha.
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET=

# ─── Observabilidade (F-M0-3) ───
# OTEL_MODE=console habilita exporter de spans no stdout em staging. Vazio/dev = no-op.
OTEL_MODE=

# ─── Feature flags (F-M0-6) ───
# Fonte canônica é Vercel Edge Config em prod; fallback é env (abaixo). Default off.
EDGE_CONFIG=
MAINNET_ENABLED=false      # M9 — kill-switch de cutover (gateia rotas mainnet)
INTL_INVESTOR_FLOW=false   # M4 — onboarding de jurisdição não-BR
SOROBAN_WATERFALL=false    # M7 — fonte do NAV/waterfall on-chain
M3_INSTITUTIONAL_GATING=false  # M3 — exige Suitability CVM 30 + ticket mínimo em /quote

# ─── Postgres (Neon — provisionar via Vercel Marketplace) ───
# DATABASE_URL  = pooled (porta 6543 ou ?pgbouncer=true) — runtime do app
# DIRECT_URL    = direct (porta 5432) — usada pelo `prisma migrate`
DATABASE_URL=
DIRECT_URL=

# ─── Painel da operação Plina (POC) ───
# Senha única em env var. Vira Clerk/Auth.js no MVP.
ADMIN_PASSWORD=

# ─── Privy (wallet embedded do investidor) ───
# Obtido em dashboard.privy.io → criar app → copiar credentials.
# Free tier 1000 MAUs. Stellar é Tier 2 (rawSign Ed25519).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Client-side: NEXT_PUBLIC_PRIVY_APP_ID expõe o appId pro PrivyProvider no browser.
# Mesmo valor de PRIVY_APP_ID; nome diferente é exigência do Next.js.
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── Upstash Redis (rate-limit em produção) ───
# Sem essas vars o app cai em rate-limit in-memory (dev/CI). Em Fluid Compute
# com múltiplas instâncias, o limite efetivo só é correto com Upstash.
# Obtido em console.upstash.com → Redis → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Etherfuse (anchor fiat ramp LATAM) ───
# Obtido em devnet.etherfuse.com → Ramp → API Keys.
# Sandbox: KYC fake auto-aprova. API key sem prefixo Bearer.
ETHERFUSE_ENV=sandbox
ETHERFUSE_API_KEY=
# Opcional — defaults: sandbox=https://api.sand.etherfuse.com · prod=https://api.etherfuse.com
ETHERFUSE_BASE_URL=

# ─── NEON ───
# Recommended for most uses
DATABASE_URL=

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=

# Parameters for constructing your own connection string
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Parameters for Vercel Postgres Templates
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
