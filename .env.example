# Plina Landing — variáveis de ambiente.
# Copie para .env.local e preencha. .env.local NUNCA vai para o git.

# ─── SMTP (lead capture institucional via app/actions/submit-lead.ts) ───
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=contato@plina.finance
SMTP_PASS=
LEAD_EMAIL_TO=

# ─── Stellar (POC + MVP) ───
# Smoke test só roda em TESTNET. Mainnet exige multisig + smart account Soroban.
STELLAR_NETWORK=TESTNET
# Opcional — defaults: testnet=https://horizon-testnet.stellar.org · public=https://horizon.stellar.org
STELLAR_HORIZON_URL=
# Asset code on-chain. Stellar não permite hífen; "PLINA-RF" é apenas branding.
ASSET_CODE=PLINARF
# Secrets do issuer/distributor — preencher após smoke test verde, com chaves persistentes.
# JAMAIS usar chaves de mainnet aqui no POC. JAMAIS commitar este arquivo preenchido.
STELLAR_ISSUER_SECRET=
STELLAR_DISTRIBUTOR_SECRET=

# ─── Postgres (Neon — provisionar via Vercel Marketplace) ───
# DATABASE_URL  = pooled (porta 6543 ou ?pgbouncer=true) — runtime do app
# DIRECT_URL    = direct (porta 5432) — usada pelo `prisma migrate`
DATABASE_URL=
DIRECT_URL=

# ─── Painel da operação Plina (POC) ───
# Senha única em env var. Vira Clerk/Auth.js no MVP.
ADMIN_PASSWORD=

# ─── Privy (wallet embedded do investidor) ───
# Obtido em dashboard.privy.io → criar app → copiar credentials.
# Free tier 1000 MAUs. Stellar é Tier 2 (rawSign Ed25519).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── Etherfuse (anchor fiat ramp LATAM) ───
# Obtido em devnet.etherfuse.com → Ramp → API Keys.
# Sandbox: KYC fake auto-aprova. API key sem prefixo Bearer.
ETHERFUSE_ENV=sandbox
ETHERFUSE_API_KEY=
# Opcional — defaults: sandbox=https://api.sand.etherfuse.com · prod=https://api.etherfuse.com
ETHERFUSE_BASE_URL=

# ─── NEON ───
# Recommended for most uses
DATABASE_URL=

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=

# Parameters for constructing your own connection string
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Parameters for Vercel Postgres Templates
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
