{
  "name": "plina-finance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "smoke:stellar": "tsx scripts/smoke-stellar.ts",
    "smoke:etherfuse": "tsx scripts/smoke-etherfuse.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "DOTENV_CONFIG_PATH=.env.local node --require dotenv/config ./node_modules/.bin/prisma migrate dev",
    "prisma:deploy": "DOTENV_CONFIG_PATH=.env.local node --require dotenv/config ./node_modules/.bin/prisma migrate deploy",
    "prisma:studio": "DOTENV_CONFIG_PATH=.env.local node --require dotenv/config ./node_modules/.bin/prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@privy-io/react-auth": "^3.26.0",
    "@privy-io/server-auth": "^1.32.5",
    "@stellar/stellar-sdk": "^13.0.0",
    "dotenv": "^16.4.7",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^6.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
