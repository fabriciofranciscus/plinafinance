// Plina — schema MVP testnet-first.
//
// Referência canônica: /home/dalekthai/Documentos/Workspace/Plina/PlinaFinance-1.pdf
// - Whitepaper §6.5: política de clawback limitada a 4 hipóteses (judicial, sanção, fraude, erro).
// - Whitepaper §3.2: AUTH_REQUIRED + AUTH_REVOCABLE + AUTH_CLAWBACK_ENABLED como features.
// - Whitepaper §6.2: três caminhos de realização (A/B/C). MVP foca em A.
// - Whitepaper §6.1: hash do documento de validação na Stellar como prova pública.
// - Whitepaper §9: dados pessoais off-chain (Brasil), on-chain só hash/endereços/timestamps.
//
// PII off-chain (CLAUDE.md). On-chain via `lib/stellar/audit` registra apenas
// hashes em memo de tx auto-pagamento na conta operacional (Plina assina em
// nome do ato — vendedor/comprador NÃO têm wallet Stellar).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum TipoBem {
  IMOVEL
  VEICULO
  EQUIPAMENTO
  SERVICO
}

/// Política de estoque envelhecido (PRD_MVP §3.4):
/// VERDE 0-45d · AMARELO 46-75d · VERMELHO 76-90d · BAIXA 90+d.
enum StatusEstoque {
  VERDE
  AMARELO
  VERMELHO
  BAIXA
}

enum StatusCota {
  DISPONIVEL
  RESERVADA
  REALIZADA
  REVERTIDA
}

/// Hipóteses exclusivas de clawback (whitepaper §6.5).
/// Adicionar uma quinta hipótese exige revisão do whitepaper e da política pública.
enum MotivoClawback {
  DECISAO_JUDICIAL
  SANCAO_REGULATORIA
  FRAUDE_DOCUMENTAL
  ERRO_OPERACIONAL
}

enum StatusInvestidor {
  PENDENTE_KYC
  AUTORIZADO
  REVOGADO
}

enum CaminhoRealizacao {
  A_REVENDA
  B_ADMINISTRADORA
  C_PRAZO_GRUPO
}

enum AcaoAudit {
  // Pool + Investidor (POC base)
  COTA_VALIDADA
  COTA_INCORPORADA
  TOKEN_EMITIDO
  INVESTIDOR_ONBOARDED
  TRUSTLINE_AUTORIZADA
  TRUSTLINE_REVOGADA
  DISTRIBUICAO
  CLAWBACK_EXECUTADO
  COTA_REALIZADA
  // Funil vendedor (MVP testnet-first)
  LEAD_VENDEDOR_CAPTURADO
  OFERTA_GERADA
  OFERTA_ACEITA
  CESSAO_ASSINADA
  PIX_SIMULADO_EXECUTADO
  // Funil comprador (MVP testnet-first)
  LEAD_COMPRADOR_CAPTURADO
  RESERVA_CRIADA
  RESERVA_EXPIRADA
  CAMINHO_A_EXECUTADO
  // Liquidação investidor (whitepaper §6.4 janela de resgate)
  PLINARF_LIQUIDADO
  // Phase 2 — onramp Etherfuse + swap atômico
  TESOURO_TRUSTLINE_AUTORIZADA
  ONRAMP_CRIADA
  ONRAMP_LIQUIDADA
  SWAP_EXECUTADO
}

// Funil vendedor

enum LeadVendedorStatus {
  NOVO
  CONTATADO
  DOCS_SOLICITADOS
  DOCS_RECEBIDOS
  OFERTA_ENVIADA
  OFERTA_ACEITA
  CESSAO_ASSINADA
  PIX_EXECUTADO
  COTA_INCORPORADA
  PERDIDO
}

enum OfertaStatus {
  RASCUNHO
  ENVIADA
  ACEITA
  REJEITADA
  EXPIRADA
}

enum CessaoStatus {
  PENDENTE
  ENVIADA_DOCUSIGN
  ASSINADA
  EXPIRADA
  CANCELADA
}

enum PagamentoStatus {
  PENDENTE
  EXECUTADO
  FALHOU
}

enum PagamentoMetodo {
  PIX_SIMULADO
  PIX_REAL
}

// Funil comprador

enum LeadCompradorTipo {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

enum LeadCompradorStatus {
  NOVO
  QUALIFICADO
  RESERVOU
  FECHOU
  PERDIDO
}

enum ReservaStatus {
  ATIVA
  EXPIRADA
  CONFIRMADA
  CANCELADA
}

// ─────────────────────────────────────────────────────────────────────────────
// Models — Pool & Investidor
// ─────────────────────────────────────────────────────────────────────────────

/// Singleton com parâmetros do issuer Stellar e do asset PLINARF.
/// Asset code on-chain é "PLINARF" (Stellar não permite hífen); "PLINA-RF" é branding.
model ParametrosPool {
  id                String   @id @default("singleton")
  assetCode         String   @default("PLINARF")
  issuerPubkey      String
  distributorPubkey String
  homeDomain        String?
  policyUrl         String?
  network           String   @default("TESTNET")
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt
}

/// Cota de consórcio contemplada. Liga-se à Cessao que a originou (quando
/// veio do funil vendedor) e à RealizacaoCaminho quando sai do pool.
/// Administradora NÃO é exposta publicamente (PRD_MVP §6.7).
model Cota {
  id                  String        @id @default(cuid())
  tipoBem             TipoBem
  administradora      String
  valorCarta          Decimal       @db.Decimal(15, 2)
  desagioAquisicao    Decimal       @db.Decimal(5, 4)
  desagioRevenda      Decimal?      @db.Decimal(5, 4)
  localizacaoAprox    String?
  prazoRestanteMeses  Int?
  caminhoPrevisto     CaminhoRealizacao @default(A_REVENDA)
  dataAquisicao       DateTime      @default(now())
  statusEstoque       StatusEstoque @default(VERDE)
  status              StatusCota    @default(DISPONIVEL)
  tokensEmitidos      Decimal       @db.Decimal(20, 7) @default(0)
  emissaoTxHash       String?
  hashCessao          String?
  /// SHA-256 do laudo de validação legal (contemplação, adimplência,
  /// titularidade) — whitepaper §6.1. Registrado on-chain via Memo.hash
  /// antes da emissão pra prova pública.
  hashValidacao       String?
  validacaoTxHash     String?
  notas               String?
  criadaEm            DateTime      @default(now())
  atualizadaEm        DateTime      @updatedAt

  /// Cessao que originou esta cota (quando veio do funil vendedor).
  /// Null em cotas seedadas / incorporadas diretamente via /admin.
  cessaoId            String?       @unique
  cessao              Cessao?       @relation(fields: [cessaoId], references: [id])

  eventos             EventoAudit[]
  reservas            Reserva[]
  realizacao          RealizacaoCaminho?

  @@index([status])
  @@index([statusEstoque])
  @@index([tipoBem])
}

/// Investidor onboarded. PII off-chain. Public key on-chain.
model Investidor {
  id              String           @id @default(cuid())
  nome            String
  email           String           @unique
  publicKey       String           @unique
  /// Privy user ID (sub do JWT). Chave estável da sessão — auth-guard
  /// resolve o investidor por aqui em vez de email pra evitar round-trip
  /// `privy.getUserById` por request. Nullable enquanto rows antigas não
  /// foram backfillada (ver scripts/backfill-privy-id.ts).
  privyId         String?          @unique
  kycAprovado     Boolean          @default(false)
  status          StatusInvestidor @default(PENDENTE_KYC)
  trustlineTxHash String?
  /// Hash da tx que estabeleceu a trustline TESOURO (asset bridge da
  /// Etherfuse). Necessário pra wallet receber TESOURO no caminho real
  /// BRL → TESOURO → PLINARF (whitepaper §6.6).
  tesouroTrustlineTxHash String?
  /// UUID do customer Etherfuse. Persistido pra idempotência (quote/order
  /// subsequentes reusam sem precisar re-criar customer).
  etherfuseCustomerId String?
  saldoEsperado   Decimal          @db.Decimal(20, 7) @default(0)
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  eventos         EventoAudit[]
  quotes          Quote[]
  onRampOrders    OnRampOrder[]

  @@index([status])
}

/// Quote BRL → TESOURO retornado pela Etherfuse, persistido pra binding
/// server-side de valor de emissão. Sem esse vínculo, /buy/submit aceitaria
/// qualquer `amount` do body — investidor poderia pedir emissão arbitrária
/// de PLINARF apenas com KYC válido e trustline assinada (gap fechado em
/// 2026-05-18: amount agora é derivado server-side de quote.toAmount).
///
/// `id` é o UUID que a Etherfuse devolve em /ramp/quote, reusado como PK.
/// `consumedAt` marca uso single-shot — quote queimado não pode reemitir.
model Quote {
  id              String   @id
  investidorId    String
  investidor      Investidor @relation(fields: [investidorId], references: [id])
  fromCurrency    String
  fromAmount      Decimal  @db.Decimal(20, 7)
  toCurrency      String
  toAmount        Decimal  @db.Decimal(20, 7)
  exchangeRate    String
  fee             String
  expiresAt       DateTime
  consumedAt      DateTime?
  /// Hash da tx Stellar que consumiu o quote (swap envelope na Phase 2,
  /// distribute single-shot na Phase 1).
  consumedTxHash  String?
  criadoEm        DateTime @default(now())

  onRampOrder     OnRampOrder?

  @@index([investidorId])
  @@index([expiresAt])
  @@index([consumedAt])
}

/// Ordem de onramp BRL → TESOURO via Etherfuse. Liga o quote ao settlement
/// real (PIX recebido off-chain → TESOURO pago on-chain pra wallet do
/// investor). Pré-condição pro swap atômico que emite PLINARF.
///
/// `id` é o orderId que a Etherfuse devolve. `stellarTxHash` é a tx de
/// payment TESOURO → investor (preenche quando status=completed).
model OnRampOrder {
  id                      String   @id
  quoteId                 String   @unique
  quote                   Quote    @relation(fields: [quoteId], references: [id])
  investidorId            String
  investidor              Investidor @relation(fields: [investidorId], references: [id])
  /// Status Etherfuse normalizado: pending | processing | completed | failed | cancelled | refunded.
  status                  String   @default("pending")
  /// Hash da tx Stellar de payment TESOURO → investor.
  stellarTxHash           String?
  /// PIX/SPEI instructions retornadas pela Etherfuse na criação da order.
  /// Persistido pra UI poder re-renderizar sem hit no Etherfuse.
  paymentInstructionsJson Json?
  settledAt               DateTime?
  criadoEm                DateTime @default(now())
  atualizadoEm            DateTime @updatedAt

  @@index([investidorId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Models — Funil vendedor (Ricardo)
// ─────────────────────────────────────────────────────────────────────────────

/// Lead capturado via /vender. PII off-chain. UTMs persistidas pra análise
/// de canal (Google Ads, parcerias, orgânico).
model LeadVendedor {
  id            String   @id @default(cuid())
  origem        String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  nome          String
  email         String   @unique
  telefone      String?
  cpf           String?
  status        LeadVendedorStatus @default(NOVO)
  motivoPerda   String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  ofertas       Oferta[]
  eventos       EventoAudit[]

  @@index([status])
  @@index([criadoEm])
}

/// Oferta firme calculada pra um lead. Pode ter múltiplas versões
/// (cada renegociação gera nova Oferta com versao++).
model Oferta {
  id                    String   @id @default(cuid())
  leadVendedorId        String
  leadVendedor          LeadVendedor @relation(fields: [leadVendedorId], references: [id])
  tipoBem               TipoBem
  valorCarta            Decimal  @db.Decimal(15, 2)
  administradora        String
  desagioAquisicao      Decimal  @db.Decimal(5, 4)
  valorLiquidoVendedor  Decimal  @db.Decimal(15, 2)
  prazoRestanteMeses    Int?
  validade              DateTime
  status                OfertaStatus @default(RASCUNHO)
  versao                Int      @default(1)
  criadaEm              DateTime @default(now())
  atualizadaEm          DateTime @updatedAt

  cessao                Cessao?
  eventos               EventoAudit[]

  @@index([leadVendedorId])
  @@index([status])
}

/// Cessão de direito creditório. Whitepaper §6.1: hash do documento na
/// Stellar como prova pública. DocuSign sandbox no POC, real no MVP+.
model Cessao {
  id                  String   @id @default(cuid())
  ofertaId            String   @unique
  oferta              Oferta   @relation(fields: [ofertaId], references: [id])
  docusignEnvelopeId  String?
  hashDocumento       String?  // SHA-256 do PDF assinado
  onChainTxHash       String?  // tx Stellar com memo hash
  assinadaEm          DateTime?
  status              CessaoStatus @default(PENDENTE)
  criadaEm            DateTime @default(now())
  atualizadaEm        DateTime @updatedAt

  pagamento           Pagamento?
  cota                Cota?
  eventos             EventoAudit[]

  @@index([status])
}

/// Pagamento ao vendedor (Pix simulado no MVP testnet, real em mainnet).
model Pagamento {
  id                String   @id @default(cuid())
  cessaoId          String   @unique
  cessao            Cessao   @relation(fields: [cessaoId], references: [id])
  metodo            PagamentoMetodo @default(PIX_SIMULADO)
  valor             Decimal  @db.Decimal(15, 2)
  onChainTxHash     String?
  executadoEm       DateTime?
  comprovanteUrl    String?
  status            PagamentoStatus @default(PENDENTE)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Models — Funil comprador-usuário (Maria + variantes PJ)
// ─────────────────────────────────────────────────────────────────────────────

/// Lead capturado via /comprar. Pode ser PF (Maria) ou PJ (construtora,
/// transportadora, empresário). Intenção de bem específica.
model LeadComprador {
  id            String   @id @default(cuid())
  origem        String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  nome          String
  email         String   @unique
  telefone      String?
  documento     String?  // CPF ou CNPJ
  tipo          LeadCompradorTipo @default(PESSOA_FISICA)
  intencaoBem   String?
  faixaCapital  String?
  prazoDecisao  String?
  status        LeadCompradorStatus @default(NOVO)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  reservas      Reserva[]
  realizacoes   RealizacaoCaminho[]
  eventos       EventoAudit[]

  @@index([status])
}

/// Reserva de cota pelo comprador-usuário. 72h por default (PRD_MVP §6.8).
/// Sinal simulado no testnet.
model Reserva {
  id                String   @id @default(cuid())
  cotaId            String
  cota              Cota     @relation(fields: [cotaId], references: [id])
  leadCompradorId   String
  leadComprador     LeadComprador @relation(fields: [leadCompradorId], references: [id])
  expiraEm          DateTime
  sinalSimulado     Decimal  @db.Decimal(15, 2) @default(0)
  onChainTxHash     String?
  status            ReservaStatus @default(ATIVA)
  criadaEm          DateTime @default(now())
  atualizadaEm      DateTime @updatedAt

  @@index([cotaId])
  @@index([status])
  @@index([expiraEm])
}

/// Realização de uma cota por um dos 3 caminhos. POC MVP foca em A.
/// Quando A: comprador-usuário concluiu a transferência de titularidade
/// e Plina capturou spread. Cota → REALIZADA. NAV/token sobe pra holders.
model RealizacaoCaminho {
  id                  String   @id @default(cuid())
  cotaId              String   @unique
  cota                Cota     @relation(fields: [cotaId], references: [id])
  caminho             CaminhoRealizacao
  leadCompradorId     String?
  leadComprador       LeadComprador? @relation(fields: [leadCompradorId], references: [id])
  valorRealizado      Decimal  @db.Decimal(15, 2)
  custoAquisicao      Decimal  @db.Decimal(15, 2)
  spread              Decimal  @db.Decimal(15, 2)
  onChainTxHash       String?
  executadaEm         DateTime @default(now())
  operador            String?

  @@index([caminho])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit log
// ─────────────────────────────────────────────────────────────────────────────

/// Append-only (CLAUDE.md). Toda mudança de estado relevante registra.
/// `payloadHash` é o SHA-256 que foi pra blockchain como memo. Vendedor/
/// comprador podem cross-verificar: hash do documento off-chain == memo
/// da tx Stellar referenciada.
model EventoAudit {
  id              String          @id @default(cuid())
  acao            AcaoAudit
  operador        String?
  motivoClawback  MotivoClawback?
  fundamentoUrl   String?
  payloadJson     Json?
  /// SHA-256 hex do payload canonicalizado. Igual ao Memo.Hash da tx.
  payloadHash     String?
  stellarTxHash   String?
  /// Privy user ID da sessão que disparou a ação. Rastreabilidade
  /// individual exigida pela CVM 175 — permite responder "qual sessão
  /// clicou no botão" em incidente. Nullable: rows antigas e fluxos
  /// admin/originador (sem sessão de investidor) ficam null.
  privyId         String?
  criadoEm        DateTime        @default(now())

  // Polymorphic-ish FKs (typed) — null exceto o relevante.
  cotaId          String?
  cota            Cota?           @relation(fields: [cotaId], references: [id])
  investidorId    String?
  investidor      Investidor?     @relation(fields: [investidorId], references: [id])
  leadVendedorId  String?
  leadVendedor    LeadVendedor?   @relation(fields: [leadVendedorId], references: [id])
  ofertaId        String?
  oferta          Oferta?         @relation(fields: [ofertaId], references: [id])
  cessaoId        String?
  cessao          Cessao?         @relation(fields: [cessaoId], references: [id])
  leadCompradorId String?
  leadComprador   LeadComprador?  @relation(fields: [leadCompradorId], references: [id])

  @@index([acao])
  @@index([cotaId])
  @@index([investidorId])
  @@index([privyId])
  @@index([leadVendedorId])
  @@index([leadCompradorId])
  @@index([cessaoId])
  @@index([criadoEm])
}
